{
  "name": "nextjs-bootstrap-template",
  "version": "0.1.2",
  "private": true,
  "description": "Agent-ready Next.js 16 + Supabase starter with auth, i18n, analytics, email, QA loops, and multi-agent coding docs.",
  "author": "Jay Nogueira <jailsom.nogueira@gmail.com>",
  "license": "MIT",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check:text-hygiene": "node scripts/check-text-hygiene.mjs",
    "check:mcp-sync": "node scripts/check-mcp-sync.mjs",
    "check": "npm run check:text-hygiene && npm run check:mcp-sync && npm run lint && npm run typecheck && npm run format:check",
    "ci-check": "npm run check && npm run test && npm run build",
    "qa": "bash scripts/qa-loop.sh",
    "qa:strict": "bash scripts/qa-loop.sh --strict",
    "qa:quiet": "bash scripts/qa-loop.sh --quiet",
    "qa:visual": "bash scripts/qa-visual-runner.sh",
    "prompt:context": "tsx scripts/prompt-context.ts",
    "pack": "npx -y repomix --include 'src/**,supabase/migrations/**,messages/**,.agents/**,AGENTS.md,CLAUDE.md,GEMINI.md' --ignore '**/*.test.ts,**/*.test.tsx,**/*.spec.ts' --output .agent-cache/repomix.xml --style xml --quiet",
    "test": "vitest run",
    "test:agent": "bash scripts/test-agent.sh",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "analyze": "ANALYZE=true next build",
    "prepare": "husky",
    "db:types": "bash scripts/generate-types.sh",
    "email:dev": "email dev --dir emails",
    "commit": "commitlint --edit",
    "push": "npx tsx scripts/generate-changelog.ts && git add CHANGELOG.md package.json package-lock.json && git commit --no-verify -m \"chore: update changelog for push\" && CHANGELOG_GENERATED=1 git push"
  },
  "dependencies": {
    "@hookform/resolvers": "5.2.2",
    "@radix-ui/react-label": "2.1.8",
    "@radix-ui/react-slot": "1.2.4",
    "@react-email/components": "1.0.12",
    "@supabase/ssr": "0.10.3",
    "@supabase/supabase-js": "2.105.4",
    "@t3-oss/env-nextjs": "0.13.11",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "date-fns": "4.1.0",
    "framer-motion": "12.38.0",
    "lucide-react": "1.16.0",
    "next": "16.2.6",
    "next-intl": "4.12.0",
    "next-themes": "0.4.6",
    "pino": "10.3.1",
    "posthog-js": "1.373.5",
    "posthog-node": "5.34.2",
    "radix-ui": "1.4.3",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-hook-form": "7.76.0",
    "resend": "6.12.3",
    "server-only": "0.0.1",
    "shadcn": "4.8.0",
    "sonner": "2.0.7",
    "tailwind-merge": "3.6.0",
    "tw-animate-css": "1.4.0",
    "zod": "4.4.3",
    "zustand": "5.0.13"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.11.3",
    "@commitlint/cli": "21.0.1",
    "@commitlint/config-conventional": "21.0.1",
    "@eslint-community/eslint-plugin-eslint-comments": "4.7.1",
    "@eslint/eslintrc": "3.3.5",
    "@next/bundle-analyzer": "16.2.6",
    "@playwright/test": "1.60.0",
    "@tailwindcss/postcss": "4.3.0",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "25.8.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "@vitest/coverage-v8": "4.1.6",
    "@vitest/ui": "4.1.6",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "eslint-import-resolver-typescript": "4.4.4",
    "husky": "9.1.7",
    "jsdom": "29.1.1",
    "lint-staged": "17.0.5",
    "playwright": "1.60.0",
    "prettier": "3.8.3",
    "prettier-plugin-tailwindcss": "0.8.0",
    "react-email": "6.1.4",
    "tailwindcss": "4.3.0",
    "tsx": "4.22.1",
    "typescript": "6.0.3",
    "typescript-eslint": "8.59.3",
    "vitest": "4.1.6"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs,cjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml,css}": [
      "prettier --write"
    ]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Jailsom-Nogueira/nextjs-bootstrap-template.git"
  },
  "keywords": [
    "nextjs",
    "nextjs-template",
    "supabase",
    "typescript",
    "tailwindcss",
    "shadcn-ui",
    "posthog",
    "resend",
    "i18n",
    "playwright",
    "vitest",
    "ai-agents",
    "agents-md"
  ],
  "bugs": {
    "url": "https://github.com/Jailsom-Nogueira/nextjs-bootstrap-template/issues"
  },
  "homepage": "https://github.com/Jailsom-Nogueira/nextjs-bootstrap-template#readme"
}
