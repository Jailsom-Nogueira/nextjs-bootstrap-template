# ─── App ─────────────────────────────────────────────────────────────────────
# Public site URL used by emails, OAuth callbacks, SEO. (required)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Node env. Set automatically by Next.js but exposed for env.ts validation.
NODE_ENV=development

# ─── Supabase ────────────────────────────────────────────────────────────────
# Project URL — Supabase Settings → API. (required)
NEXT_PUBLIC_SUPABASE_URL=
# Anon (public) key — safe in the browser. (required)
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key — SERVER ONLY. Never expose to client. (required for admin ops)
SUPABASE_SERVICE_ROLE_KEY=
# Project ref for `npm run db:types`. (optional)
SUPABASE_PROJECT_REF=

# ─── PostHog ─────────────────────────────────────────────────────────────────
# Client-side PostHog key. (optional — analytics off if missing)
NEXT_PUBLIC_POSTHOG_KEY=
# Host (use /ingest reverse proxy in prod). (optional, defaults to /ingest)
NEXT_PUBLIC_POSTHOG_HOST=/ingest
# Server-side PostHog key (usually same as client). (optional)
POSTHOG_API_KEY=

# ─── Resend (email) ──────────────────────────────────────────────────────────
# API key. (optional — emails off if missing)
RESEND_API_KEY=
# Default from address.
EMAIL_FROM="Your App <hello@yourdomain.com>"
